# ════════════════════════════════════════════════════════════
#  Vizzor — Environment Configuration
#  Copy this file to `.env` and fill in your own values.
#  NEVER commit your real .env file.
# ════════════════════════════════════════════════════════════

# ───────────── App ─────────────
VIZZOR_ENV=development            # development | production
VIZZOR_BACKEND_PORT=8000
VIZZOR_FRONTEND_URL=http://localhost:5173

# ───────────── Authentication ─────────────
# Strategy: jwt | oauth | oidc
VIZZOR_AUTH_STRATEGY=jwt

# JWT (used when VIZZOR_AUTH_STRATEGY=jwt)
VIZZOR_JWT_SECRET=change-me-to-a-long-random-string
VIZZOR_JWT_ALGORITHM=HS256
VIZZOR_JWT_EXPIRES_MINUTES=60

# OAuth / OIDC (used when strategy=oauth|oidc)
VIZZOR_OIDC_ISSUER=
VIZZOR_OIDC_CLIENT_ID=
VIZZOR_OIDC_CLIENT_SECRET=
VIZZOR_OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# ───────────── BI Providers ─────────────
# Comma-separated list of enabled connectors, e.g. "tableau,powerbi"
VIZZOR_PROVIDERS=tableau

# ----- Tableau (Connected Apps for embedding) -----
TABLEAU_SITE_URL=https://your-tableau-site.example.com
TABLEAU_SITE_ID=your-site-content-url
TABLEAU_CONNECTED_APP_CLIENT_ID=
TABLEAU_CONNECTED_APP_SECRET_ID=
TABLEAU_CONNECTED_APP_SECRET_VALUE=
TABLEAU_API_VERSION=3.21

# ----- Power BI (placeholder — roadmap) -----
# POWERBI_TENANT_ID=
# POWERBI_CLIENT_ID=
# POWERBI_CLIENT_SECRET=

# ───────────── Database (optional — for catalog/users) ─────────────
# Leave blank to use in-memory/SQLite for local dev.
VIZZOR_DATABASE_URL=sqlite:///./vizzor.db
